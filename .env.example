# Telegram
BOT_TOKEN=your-telegram-bot-token
WEBAPP_URL=https://your-domain.com
WEBHOOK_URL=
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080

# Database (required) — postgresql://user:password@host:5432/dbname
DATABASE_URL=postgresql://user:password@localhost:5432/promptw_db

# External generation API (without it the StubGenerator is used)
KIE_API_KEY=

# Text chat (OpenRouter) — required for the "Текст" section
OPENROUTER_API_KEY=

# Directory for downloaded media files (local fallback + legacy file serving)
MEDIA_DIR=/opt/tg-image-ai-bot/media

# ── File storage ──
# STORAGE_BACKEND: "s3" or "local". If unset, auto = s3 when the S3_* vars below
# are all set, otherwise local (dev/StubGenerator). S3 objects are uploaded
# public-read and addressed by their direct path-style URL. Legacy /media/<file>
# rows keep working (served from MEDIA_DIR). Secrets live ONLY here on the VPS.
STORAGE_BACKEND=s3
S3_ENDPOINT=https://s3.ru1.storage.beget.cloud
S3_BUCKET=your-bucket-name
S3_REGION=ru1
S3_ACCESS_KEY=
S3_SECRET_KEY=
# Object key prefix inside the bucket (default: media)
S3_PREFIX=media

# Security: validate Telegram WebApp initData on /api/* (1 = enforce, 0 = allow unauthenticated)
AUTH_ENFORCE=1

# Billing: deduct tokens before generation/chat (1 = enforce + 402 on empty balance,
# 0 = compute & record cost only, no deduction/blocking)
BILLING_ENFORCE=1
# Tokens credited to a user on first /start (0 = none). Useful while payments aren't wired.
WELCOME_BONUS=100

# Telegram ids (comma-separated) allowed to view/process withdrawal requests
ADMIN_IDS=

# ── Payments ──
# ЮKassa (RF) — REST API. shopId + secret key (test_… or live_…) from the dashboard.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Set the webhook (payment.succeeded) in the ЮKassa dashboard to WEBHOOK_URL + /api/pay/yoomoney

# Platega (CIS) — https://platega.io . Credentials issued in the dashboard (Settings).
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
PLATEGA_BASE=https://app.platega.io
# Default payment method: 11=card, 2=SBP, 13=crypto
PLATEGA_METHOD=11
# Set the callback URL in the Platega dashboard to WEBHOOK_URL + /api/pay/platega
